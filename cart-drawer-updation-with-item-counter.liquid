function updateCartDrawer() {
  const cartUrl = ${window.Shopify.routes.root}cart?section_id=cart-drawer;

  fetch(cartUrl)
    .then((res) => res.text())
    .then((html) => {

      const tempDiv = document.createElement("div");
      tempDiv.innerHTML = html;

      const newDrawer = tempDiv.querySelector('cart-drawer');
      const currentDrawer = document.querySelector('cart-drawer');

      if (newDrawer && currentDrawer) {

        // update only inner content
        currentDrawer.innerHTML = newDrawer.innerHTML;

        // keep drawer open
        currentDrawer.classList.add('animate', 'active');
        document.body.classList.add('overflow-hidden');

        console.log('Cart drawer updated without closing');
      }
    })
    .catch((err) => console.error("Cart fetch error:", err));
}


function updateCartCount() {

  fetch(${window.Shopify.routes.root}cart.js)
    .then(res => res.json())
    .then(cart => {

      const count = cart.item_count;

      document.querySelectorAll('.cart-count-badge').forEach((badge) => {

        if(count > 0){
          badge.textContent = count;
          badge.style.display = 'flex';
        } else {
          badge.style.display = 'none';
        }

      });

    });

}
